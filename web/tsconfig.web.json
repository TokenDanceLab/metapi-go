{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "rootDir": "."
  },
  "include": [
    "*.ts",
    "*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "shared/**/*.js",
    "vite-env.d.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.architecture.test.ts",
    "**/*.architecture.test.tsx",
    "node_modules",
    "dist"
  ]
}
