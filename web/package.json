{
  "name": "metapi",
  "version": "0.8.45",
  "private": true,
  "description": "Meta-layer management and unified proxy for AI API aggregation platforms",
  "keywords": [
    "ai",
    "api-gateway",
    "proxy",
    "vite",
    "react",
    "openai",
    "claude",
    "aggregator"
  ],
  "homepage": "https://github.com/TokenDanceLab/metapi-go#readme",
  "bugs": {
    "url": "https://github.com/TokenDanceLab/metapi-go/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenDanceLab/metapi-go.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=25.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "desktop:icons": "node scripts/desktop/generate-icons.mjs",
    "build:web": "npm run desktop:icons && vite build",
    "build": "npm run build:web",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "typecheck:web:test": "tsc -p tsconfig.web.test.json",
    "typecheck": "npm run typecheck:web && npm run typecheck:web:test",
    "audit:prod": "npm audit --audit-level=high --omit=dev",
    "audit": "npm audit --audit-level=moderate",
    "docs:dev": "node ./scripts/docs-optional.mjs dev",
    "docs:build": "node ./scripts/docs-optional.mjs build",
    "docs:preview": "node ./scripts/docs-optional.mjs preview",
    "test": "vitest run --root .",
    "test:watch": "vitest --root .",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual-gallery.spec.ts",
    "test:visual:update": "playwright test e2e/visual-gallery.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@visactor/react-vchart": "^2.0.22",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.15.0",
    "react-test-renderer": "19.2.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "~4.1.10"
  },
  "overrides": {
    "minimist": "^1.2.8"
  },
  "author": {
    "name": "TokenDanceLab",
    "url": "https://github.com/TokenDanceLab"
  }
}
