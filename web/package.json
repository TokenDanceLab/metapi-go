{
  "name": "metapi",
  "version": "0.6.3",
  "private": true,
  "description": "Meta-layer management and unified proxy for AI API aggregation platforms",
  "keywords": [
    "ai",
    "api-gateway",
    "proxy",
    "vite",
    "react",
    "openai",
    "claude",
    "aggregator"
  ],
  "homepage": "https://github.com/TokenDanceLab/metapi-go#readme",
  "bugs": {
    "url": "https://github.com/TokenDanceLab/metapi-go/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenDanceLab/metapi-go.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=25.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "desktop:icons": "node scripts/desktop/generate-icons.mjs",
    "build:web": "npm run desktop:icons && vite build",
    "build": "npm run build:web",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "typecheck:web:test": "tsc -p tsconfig.web.test.json",
    "typecheck": "npm run typecheck:web && npm run typecheck:web:test",
    "audit:prod": "npm audit --audit-level=high --omit=dev",
    "audit": "npm audit --audit-level=moderate",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 4173",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 4173",
    "test": "vitest run --root .",
    "test:watch": "vitest --root ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@visactor/react-vchart": "^2.0.22",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0",
    "react-test-renderer": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "minimist": "^1.2.8",
    "vitepress": {
      "vite": "^6.4.3"
    }
  },
  "author": {
    "name": "TokenDanceLab",
    "url": "https://github.com/TokenDanceLab"
  }
}
